# =============================================================================
# MattrMindr — Application Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.

# --- Database (PostgreSQL / AWS Aurora PostgreSQL-Compatible) ---
# Connection string for PostgreSQL. For Aurora, use the writer endpoint:
# postgresql://username:password@your-cluster.cluster-abc123.us-east-1.rds.amazonaws.com:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# SSL configuration for database connections
# Set to the path of the AWS RDS/Aurora CA certificate bundle (e.g., ./global-bundle.pem)
# Download from: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# RDS_SSL_CA=./global-bundle.pem

# Enable SSL without a custom CA cert (uses system trust store)
# DB_SSL=true

# --- Database Connection Pool ---
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=10000
# DB_STATEMENT_TIMEOUT=60000

# --- Aurora Read Replica (Optional) ---
# DATABASE_READ_URL=postgresql://username:password@your-cluster.cluster-ro-abc123.us-east-1.rds.amazonaws.com:5432/dbname

# --- AWS S3 (File Storage) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# --- Session ---
SESSION_SECRET=your-session-secret

# --- Node Environment ---
NODE_ENV=development

# =============================================================================
# Pilot / Multi-Tenant Configuration
# =============================================================================

# --- Mail Domain (Inbound Email) ---
# The domain used for inbound case email addresses (e.g., case-123@yourdomain.com).
# Must match your SendGrid Inbound Parse hostname.
# Default: plaintiff.mattrmindr.com
# MAIL_DOMAIN=plaintiff.andycitrin.mattrmindr.com

# --- Application URL ---
# The public-facing URL of this deployment. Used in password-reset emails and links.
# Falls back to REPLIT_DEV_DOMAIN, then mattrmindr.replit.app.
# APP_URL=https://andycitrin.mattrmindr.com

# --- CORS Origins ---
# Comma-separated list of allowed origins for CORS in production.
# Required when serving the frontend from a custom domain.
# CORS_ORIGINS=https://andycitrin.mattrmindr.com,https://www.andycitrin.mattrmindr.com

# --- Support Email ---
# Email address that receives support requests from the in-app support form.
# Default: support@mattrmindr.com
# SUPPORT_EMAIL=support@mattrmindr.com

# --- Admin Seed ---
# Email and password for the auto-seeded admin user (created on first startup if missing).
# ADMIN_EMAIL=admin@firmname.com
# ADMIN_PASSWORD=YourSecurePassword

# =============================================================================
# Third-Party Integrations
# =============================================================================

# --- SendGrid (Email) ---
# SENDGRID_API_KEY=SG.xxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_REPLY_TO=support@yourdomain.com

# --- Twilio (SMS / Voice) ---
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Microsoft 365 (OAuth / Calendar / OneDrive) ---
# MS_CLIENT_ID=your-app-client-id
# MS_CLIENT_SECRET=your-app-client-secret
# MS_TENANT_ID=your-tenant-id
# MS_REDIRECT_URI=https://yourdomain.com/api/microsoft/callback

# --- ONLYOFFICE DocSpace ---
# ONLYOFFICE_URL=https://your-docspace.onlyoffice.com
# ONLYOFFICE_PASSWORD=your-docspace-admin-password
# ONLYOFFICE_USER=admin
# ONLYOFFICE_ROOM_ID=your-room-id

# --- AI (OpenAI-compatible) ---
# These are typically set by the Replit OpenAI integration:
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxx
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
