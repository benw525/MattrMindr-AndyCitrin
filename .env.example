# =============================================================================
# Application Environment Variables
# =============================================================================

# --- Database (PostgreSQL / AWS RDS) ---
# Connection string for PostgreSQL. For AWS RDS, use:
# postgresql://username:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# SSL configuration for database connections
# Set to the path of the AWS RDS CA certificate bundle (e.g., ./global-bundle.pem)
# Or set to the PEM certificate content directly
# Download from: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# When set, SSL is enabled with certificate verification (rejectUnauthorized: true)
# RDS_SSL_CA=./global-bundle.pem

# Enable SSL without a custom CA cert (uses system trust store, rejectUnauthorized: true)
# DB_SSL=true

# Disable SSL explicitly (not recommended for production)
# DB_SSL=false

# --- Database Connection Pool ---
# Max number of connections in the pool (default: 20)
# DB_POOL_MAX=20

# Idle connection timeout in milliseconds (default: 30000)
# DB_IDLE_TIMEOUT=30000

# Connection timeout in milliseconds (default: 10000)
# DB_CONNECTION_TIMEOUT=10000

# Statement timeout in milliseconds (default: 60000)
# DB_STATEMENT_TIMEOUT=60000

# --- AWS S3 (File Storage) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# --- Session ---
SESSION_SECRET=your-session-secret

# --- Node Environment ---
NODE_ENV=development
