{\pard\sb100\sa100\f1\fs20\cf1
/\line
\emdash  package.json          Root monorepo (concurrently runs server + frontend)\line
\emdash  server/\line
   \emdash  index.js            Express entry, middleware, route mounting, migrations\line
   \emdash  db.js               pg Pool singleton (DATABASE_URL)\line
   \emdash  schema.js           Initial CREATE TABLE statements\line
   \emdash  seed.js             Seed data importer\line
   \emdash  email.js            SendGrid wrapper\line
   \emdash  sms.js              Twilio wrapper\line
   \emdash  sms-scheduler.js    Background SMS reminder scheduler\line
   \emdash  r2.js               Cloudflare R2 S3 client\line
   \emdash  utils/\line
      \emdash  extract-text.js  OCR pipeline (Gemini > Tesseract fallback)\line
   \emdash  middleware/\line
      \emdash  auth.js          requireAuth (firm users)\line
      \emdash  clientAuth.js    requireClientAuth (portal users)\line
      \emdash  external-auth.js requireExternalAuth (JWT bearer)\line
   \emdash  routes/             60+ route files (\wave16,000 lines total)\line
      \emdash  auth.js, cases.js, tasks.js, deadlines.js, ...\line
\emdash  lextrack/\line
   \emdash  src/\line
      \emdash  App.js            Entire firm UI (\wave21,000 lines)\line
      \emdash  api.js            API fetch wrapper (\wave816 lines)\line
      \emdash  CollaborateView.js  Internal chat\line
      \emdash  TrialCenterView.js  Trial prep\line
      \emdash  DocViewerWindow.js  Floating document viewer\line
      \emdash  portal/\line
